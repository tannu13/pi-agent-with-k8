APP_PORT=3000
NODE_ENV=development
APP_STAGE=dev

K8_NAMESPACE=default
K8_LABEL=sandbox-runner
K8_CONTAINER=runner
SANDBOX_COUNT=8
SANDBOX_WORKDIR=/workspace

LEASE_DURATION_SECONDS=45
QUEUE_MAX_WAIT_MS=15000
TOOL_TIMEOUT_MS=30000
SERVICE_INSTANCE_ID=api-local-1

PI_PROVIDER=google
PI_MODEL=gemma-4-26b-a4b-it
GEMINI_API_KEY=
RUN_PI_SMOKE=0
